{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(pnpx:*)",
      "Bash(printf:*)",
      "Bash(ls:*)",
      "Bash(expect:*)",
      "Bash(cat:*)",
      "Bash(supabase:*)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Bash(done)",
      "Bash(gh auth:*)",
      "Bash(curl:*)",
      "Bash(find:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify-linear-sync.sh",
            "statusMessage": "Checking for tasks.md changes..."
          }
        ]
      }
    ]
  }
}
