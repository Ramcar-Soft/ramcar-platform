{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(pnpx:*)",
      "Bash(printf:*)",
      "Bash(ls:*)",
      "Bash(expect:*)",
      "Bash(cat:*)",
      "Bash(supabase:*)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Bash(done)",
      "Bash(gh auth:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(.specify/scripts/bash/check-prerequisites.sh --json --paths-only)",
      "Bash(.specify/scripts/bash/setup-plan.sh --json)",
      "Bash(.specify/scripts/bash/update-agent-context.sh claude:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify-linear-sync.sh",
            "statusMessage": "Checking for tasks.md changes..."
          }
        ]
      }
    ]
  }
}
