{
  "extends": "@ramcar/config/tsconfig.node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "sourceMap": true,
    "declaration": true,
    "types": ["jest", "node"]
  },
  "ts-node": {
    "transpileOnly": true,
    "ignore": ["node_modules/(?!@ramcar)"],
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "Node"
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
