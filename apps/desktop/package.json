{
  "name": "@ramcar/desktop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dist": "tsc && vite build && electron-builder",
    "release": "tsc && vite build && electron-builder --publish always",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
