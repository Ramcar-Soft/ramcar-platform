    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "@ramcar/features": "workspace:*",
    "@ramcar/i18n": "workspace:*",
    "@ramcar/shared": "workspace:*",
    "@ramcar/store": "workspace:*",
    "@ramcar/ui": "workspace:*",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.97.0",
    "lucide-react": "^1.7.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "zustand": "^5.0.12"
